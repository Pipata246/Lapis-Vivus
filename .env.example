BOT_TOKEN=.................................
WEBHOOK_URL=.................................
WEBHOOK_SECRET=.................................

SUPABASE_URL=.................................
SUPABASE_SERVICE_ROLE_KEY=.................................

GPTUNNEL_API_KEY=.................................
GPTUNNEL_MODEL=gpt-4o-mini
GPTUNNEL_USE_WALLET=true

# Промпты: 1 = Supabase, 0 = локальные файлы src/prompts/
PROMPTS_USE_DB=1

# Python compute-сервис на VPS (Human Design, блок 1A)
COMPUTE_API_URL=https://calc.yourdomain.ru
COMPUTE_API_SECRET=.................................

# ЮKassa — пополнение баланса
YOOKASSA_SHOP_ID=.................................
YOOKASSA_SECRET_KEY=.................................
YOOKASSA_RETURN_URL=https://t.me/YourBot
#
# Telegram webhook (бот) — настроить ОДИН РАЗ:
#   npm run webhook:set
#   или открыть /api/register-webhook?key=WEBHOOK_SECRET
#
# ЮKassa webhook (оплата) — скрипт НЕ нужен, только URL в кабинете ЮKassa:
#   https://<домен-vercel>/api/yookassa-webhook
#   событие: payment.succeeded
