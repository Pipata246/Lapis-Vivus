BOT_TOKEN=.................................
WEBHOOK_URL=.................................
WEBHOOK_SECRET=.................................

SUPABASE_URL=.................................
SUPABASE_SERVICE_ROLE_KEY=.................................

GPTUNNEL_API_KEY=.................................
GPTUNNEL_MODEL=gpt-4o-mini
GPTUNNEL_USE_WALLET=true

# Промпты: 1=из Supabase, 0=только локальные файлы src/prompts/
PROMPTS_USE_DB=1
# full=весь blocks (~180k), single=только текущий блок (экономия ~75%)
PROMPTS_BLOCKS_MODE=single
# calculators.txt — ссылки для кнопок, в ИИ не нужен (0)
PROMPTS_INCLUDE_CALCULATORS=0
PROMPTS_INCLUDE_GLOSSARY=1
PROMPTS_INCLUDE_BIBLIOGRAPHY=1
# summary=сжимать прошлые ответы в истории, full=как было
CHAT_AI_HISTORY_MODE=summary
# 1=лог размеров частей промпта в консоль
PROMPTS_DEBUG=0
