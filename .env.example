BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
WEBHOOK_URL=https://lapis-vivus.vercel.app/api/webhook

# Supabase (только для /start — сохранение пользователя)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GPTunnel — ТОЛЬКО латиница/цифры (кириллица в конце ключа ломает запрос!)
GPTUNNEL_API_KEY=your-gptunnel-api-key
# id модели из GET https://gptunnel.ru/v1/models (не название из интерфейса)
GPTUNNEL_MODEL=gpt-4o-mini
# true = списание с личного кошелька (по умолчанию). false = бизнес-счёт
GPTUNNEL_USE_WALLET=true
