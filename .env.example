BOT_TOKEN=.................................
WEBHOOK_URL=.................................
WEBHOOK_SECRET=.................................

SUPABASE_URL=.................................
SUPABASE_SERVICE_ROLE_KEY=.................................

GPTUNNEL_API_KEY=.................................
GPTUNNEL_MODEL=gpt-4o-mini
GPTUNNEL_USE_WALLET=true

# Публичный URL деплоя (страницы /legal/*). На Vercel можно не задавать — подставится VERCEL_URL.
SITE_URL=https://your-project.vercel.app

# Обязательная подписка на сообщество (getChatMember). По умолчанию @LapisVivus.
# Бот должен быть администратором канала/группы.
# COMMUNITY_CHAT_ID=@LapisVivus

# Промпты: 1 = Supabase, 0 = локальные файлы src/prompts/
PROMPTS_USE_DB=1

# Python compute-сервис на VPS (Human Design, блок 1A)
COMPUTE_API_URL=https://calc.yourdomain.ru
COMPUTE_API_SECRET=.................................

# ЮKassa — пополнение баланса
YOOKASSA_SHOP_ID=.................................
YOOKASSA_SECRET_KEY=.................................
YOOKASSA_RETURN_URL=https://t.me/YourBot
#
# Telegram webhook (бот) — один раз: npm run webhook:set
#
# ЮKassa HTTP-уведомления (оплата, мгновенно после оплаты):
#   https://<домен>/api/yookassa-webhook  ·  payment.succeeded
#
# Фоновая проверка pending (каждые 2 мин, если webhook не дошёл):
#   Vercel Cron → /api/sync-payments
#   На Vercel задай CRON_SECRET (можно = WEBHOOK_SECRET)
CRON_SECRET=..................................
